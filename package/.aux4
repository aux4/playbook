{
  "scope": "aux4",
  "name": "playbook",
  "version": "2.0.1",
  "description": "Natural language script execution engine",
  "license": "Apache-2.0",
  "git": "https://github.com/aux4/playbook",
  "dependencies": [
    "aux4/config"
  ],
  "tags": [
    "aux4",
    "playbook",
    "natural-language",
    "scripting",
    "automation"
  ],
  "profiles": [
    {
      "name": "main",
      "commands": [
        {
          "name": "playbook",
          "execute": [
            "profile:playbook"
          ],
          "help": {
            "text": "Natural language script execution"
          }
        }
      ]
    },
    {
      "name": "playbook",
      "commands": [
        {
          "name": "execute",
          "execute": [
            "node ${packageDir}/lib/aux4-playbook.mjs execute values(file,actions,loadActions) value(*)"
          ],
          "help": {
            "text": "Execute a playbook script file",
            "variables": [
              {
                "name": "file",
                "text": "Path to the playbook script file",
                "arg": true
              },
              {
                "name": "actions",
                "text": "Action definitions from config.yaml",
                "default": "[]"
              },
              {
                "name": "loadActions",
                "text": "Comma-separated list of actions to load (default: all)",
                "default": ""
              }
            ]
          }
        },
        {
          "name": "list",
          "execute": [
            "node ${packageDir}/lib/aux4-playbook.mjs list"
          ],
          "help": {
            "text": "List all registered actions"
          }
        },
        {
          "name": "actions",
          "execute": [
            "profile:playbook:actions"
          ],
          "help": {
            "text": "Manage playbook action plugins"
          }
        }
      ]
    },
    {
      "name": "playbook:actions",
      "commands": []
    }
  ]
}
